generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id String @id @default(uuid())
  username String @unique
  email String @unique
  password String 
  userTicket Ticket[]
}

model Event {
  id String @id @default(uuid())
  eventName String 
  eventDetail String
  totalTickets Int
  availableTickets Int
}

model Ticket {
  id String @id @default(uuid())
  userId String
  eventId String
  price Float
  status TICKETSTATUS @default(AVAILABLE)
  user User @relation(fields: [userId],references: [id])
}

enum TICKETSTATUS {
  AVAILABLE 
  BOOKED
  CANCELLED
}