generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id String @id @default(uuid())
  username String @unique
  email String @unique
  password String 
  userTicket Ticket[]
  userSeat Seat[]
}

model Event {
  id String @id @default(uuid())
  eventName String 
  eventDetail String
  availableTickets Int
}

model Ticket {
  id String @id @default(uuid())
  userId String
  eventId String
  price Float
  user User @relation(fields: [userId],references: [id])
  seatNumber String
}


model Seat {
  id String @id @default(uuid())
  venue VENUE
  userId String
  seatNumber String @unique
  eventId String 
  user User @relation(fields: [userId],references: [id])
  ticketId String
}

enum VENUE {
  VIP
  REGULAR 
  BALCONY
}

enum TICKETSTATUS {
  AVAILABLE 
  BOOKED
  RESERVED
}